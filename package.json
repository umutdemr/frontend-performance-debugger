{
  "name": "fpd",
  "version": "1.0.2",
  "private": true,
  "description": "Frontend Performance Debugger — open-source developer tool for analyzing frontend performance",
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "pnpm -r run build",
    "build:types": "pnpm --filter @fpd/shared-types run build",
    "build:core": "pnpm --filter @fpd/core run build",
    "build:cli": "pnpm --filter @fpd/cli run build",
    "dev": "pnpm -r run dev",
    "clean": "pnpm -r run clean && rm -rf node_modules",
    "typecheck": "pnpm -r run typecheck",
    "lint": "pnpm -r run lint"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "tsup": "^8.3.6",
    "@types/node": "^22.10.10"
  }
}
